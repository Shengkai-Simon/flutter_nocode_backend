# .env.example — copy this to .env and fill in your values
# cp .env.example .env

# ── Spring Cloud Config Server ──────────────────────────────────────────────
CONFIG_SERVER_URL=http://config-service:8888

# ── Eureka Service Registry ──────────────────────────────────────────────────
EUREKA_URL=http://discovery-service:8761/eureka

# ── JWT Issuer URI ───────────────────────────────────────────────────────────
JWT_ISSUER_URI=http://auth-service:9000

# ── PostgreSQL (host = docker service name) ──────────────────────────────────
POSTGRE_SQL=jdbc:postgresql://postgres:5432

# ── Redis (host = docker service name) ───────────────────────────────────────
REDIS_HOST=redis

# ── RabbitMQ (host = docker service name) ────────────────────────────────────
RABBITMQ_HOST=rabbitmq

# ── SMTP / Mail ───────────────────────────────────────────────────────────────
MAIL_HOST=smtp.your-email-provider.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-secret-app-password

# ── Third-Party OAuth ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
APPLE_CLIENT_ID=your-apple-client-id
APPLE_CLIENT_SECRET=your-apple-client-secret
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# ── Admin Seed Account ────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# ── Internal Service-to-Service API Keys ─────────────────────────────────────
# Generate with: openssl rand -base64 32
INTERNAL_API_KEY_PRIMARY=your-primary-key
INTERNAL_API_KEY_SECONDARY=your-secondary-key

# ── RSA Key Pair (used by auth-service for JWT signing) ──────────────────────
# Generate with:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out private.pem
#   openssl pkcs8 -topk8 -inform PEM -outform DER -in private.pem -nocrypt | base64 -w 0
#   openssl rsa -in private.pem -pubout -outform DER | base64 -w 0
RSA_PRIVATE_KEY=your-pkcs8-der-base64-encoded-private-key
RSA_PUBLIC_KEY=your-der-base64-encoded-public-key

# ── MCP Service (Node.js / Prisma) ───────────────────────────────────────────
MCP_DATABASE_URL="postgresql://user:pass@postgres:5432/mcpdb?schema=public"
GEMINI_API_KEY=your-gemini-api-key
